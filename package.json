    "minify:js": "uglifyjs js/main.js --compress --mangle --output js/main.min.js"
  },
  "devDependencies": {
    "serve": "^14.2.3",
    "clean-css-cli": "^5.6.3",
    "uglify-js": "^3.18.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ]
}