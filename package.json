{
  "name": "22pm-business",
  "version": "1.0.0",
  "description": "22PM — Zero-capital AI workflow automation platform. Drop-servicing AI workflows for agencies, real estate, consulting, e-commerce, and clinics.",
  "private": true,
  "scripts": {
    "dev": "serve -s -l 3000",
    "start": "serve -s -l 3000",
    "preview": "serve -s -l 8080",
